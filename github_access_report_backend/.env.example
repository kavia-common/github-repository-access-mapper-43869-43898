# GitHub Personal Access Token (required)
# Create at https://github.com/settings/tokens
# Required scopes: read:org, repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Default GitHub organization to scan (optional — can be overridden via ?org= query param)
GITHUB_ORG=your-org-name
